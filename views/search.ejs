<%- include('partials/head') %>
<h2>Document Search</h2>
<form method="get" action="/search" class="card">
  <label>Search title <input name="q" value="<%= q %>"></label>
  <button type="submit">Search</button>
</form>

<% if (q) { %>
  <% if (rawEcho) { %>
    <%# LEGACY: query reflected WITHOUT output encoding (demonstrates reflected XSS) %>
    <p>Results for: <%- q %></p>
  <% } else { %>
    <%# MODERN: query reflected WITH output encoding (safe) %>
    <p>Results for: <%= q %></p>
  <% } %>

  <ul>
    <% results.forEach(function (d) { %>
      <li><%= d.title %> [<%= d.classification %>]</li>
    <% }); %>
  </ul>
  <% if (results.length === 0) { %><p>No matching documents.</p><% } %>
<% } %>
<%- include('partials/foot') %>
